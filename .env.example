# Base URL for E2E tests
E2E_BASE_URL=https://the-internet.herokuapp.com

# Log level (error, warn, info, debug)
E2E_LOG_LEVEL=info

# Run in headed mode
PLAYWRIGHT_HEADED=false

# Number of parallel workers
PLAYWRIGHT_WORKERS=4

# Pause browser on test failure
E2E_DEBUG=false

# CI mode
CI=false

# MCP idle timeout (ms, default 20 min)
# MCP_IDLE_TIMEOUT_MS=1200000

# Syngrisi visual testing
SYNGRISI_BASE_URL=http://localhost:5566/
SYNGRISI_DB_URI=mongodb://127.0.0.1:27017/e2eBoilerplateSyngrisiDB
SYNGRISI_PROJECT=MyProject
SYNGRISI_BRANCH=main
SYNGRISI_API_KEY=
# DISABLE_VISUAL_CHECKS=true
